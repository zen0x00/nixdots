#!/usr/bin/env bash
set -euo pipefail

cleanup() {
  [[ -n "${freeze_pid:-}" ]] && kill "$freeze_pid" 2>/dev/null || true
}

trap cleanup EXIT

hyprpicker -r -z >/dev/null 2>&1 &
freeze_pid=$!
sleep 0.1

selection="$(slurp 2>/dev/null || true)"
[[ -z "$selection" ]] && exit 0

text="$(
  grim -g "$selection" - \
    | tesseract stdin stdout --oem 1 --psm 6 -l eng --dpi 300 -c preserve_interword_spaces=1 2>/dev/null
)" || exit 1

[[ -z "$text" ]] && exit 1

printf "%s" "$text" | wl-copy
command -v notify-send >/dev/null 2>&1 && notify-send "OCR copied" "Text copied to clipboard"
