#!/usr/bin/env bash
set -euo pipefail

terminals_file="${XDG_CONFIG_HOME:-$HOME/.config}/xdg-terminals.list"

if (($# == 0)); then
  awk '!/^($|#)/{print; exit}' "$terminals_file" 2>/dev/null | sed 's/\.desktop$//'
  exit 0
fi

case "$1" in
  kitty) desktop_id="kitty.desktop"; command_name="kitty" ;;
  ghostty) desktop_id="com.mitchellh.ghostty.desktop"; command_name="ghostty" ;;
  foot) desktop_id="foot.desktop"; command_name="foot" ;;
  alacritty) desktop_id="Alacritty.desktop"; command_name="alacritty" ;;
  *)
    echo "Usage: zen0x-default-terminal [kitty|ghostty|foot|alacritty]" >&2
    exit 1
    ;;
esac

mkdir -p "$(dirname "$terminals_file")"
cat > "$terminals_file" <<EOF
# Terminal emulator preference order for xdg-terminal-exec
$desktop_id
EOF

hyprctl reload >/dev/null 2>&1 || true
command -v notify-send >/dev/null 2>&1 && notify-send "Default terminal" "$1"
