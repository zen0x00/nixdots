#!/usr/bin/env bash
set -euo pipefail

font_name="${*:-}"
[[ -z "$font_name" ]] && { echo "Usage: zen0x-font-set <font name>" >&2; exit 1; }

if ! fc-list | grep -Fqi "$font_name"; then
  echo "Font not found: $font_name" >&2
  exit 1
fi

config_root="${XDG_CONFIG_HOME:-$HOME/.config}"
kitty_conf="$config_root/kitty/kitty.conf"

if [[ -f "$kitty_conf" ]]; then
  sed -i "/# BEGIN_KITTY_FONTS/,/# END_KITTY_FONTS/s|font_family.*|font_family      family=\"$font_name\"|" "$kitty_conf"
fi

replace_font() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  perl -0pi -e 's/JetBrainsMono Nerd Font (?:Mono|Propo)?/'"$font_name"'/g' "$file"
}

replace_font "$config_root/waybar/style.css"
replace_font "$config_root/swaync/style.css"

command -v pkill >/dev/null 2>&1 && pkill -USR1 kitty 2>/dev/null || true
command -v notify-send >/dev/null 2>&1 && notify-send "Font updated" "$font_name"
