#!/usr/bin/env bash
set -euo pipefail

# zen0x:summary=Cycle audio outputs while keeping mute state.

notify_audio() {
  local message="$1"
  if command -v swayosd-client >/dev/null 2>&1; then
    swayosd-client --custom-message "$message"
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send "Audio output" "$message"
  fi
}

sinks="$(pactl -f json list sinks | jq '[.[] | select((.ports | length == 0) or ([.ports[]? | .availability != "not available"] | any))]')"
count="$(jq 'length' <<<"$sinks")"

if (( count == 0 )); then
  notify_audio "No audio devices found"
  exit 1
fi

current_name="$(pactl get-default-sink)"
current_index="$(jq -r --arg name "$current_name" 'map(.name) | index($name)' <<<"$sinks")"

if [[ "$current_index" == "null" ]]; then
  next_index=0
else
  next_index=$(((current_index + 1) % count))
fi

next_name="$(jq -r ".[$next_index].name" <<<"$sinks")"
next_description="$(jq -r ".[$next_index].description // .[$next_index].properties[\"device.description\"] // .[$next_index].properties[\"node.description\"] // .[$next_index].name" <<<"$sinks")"
mute_state="$(pactl get-sink-mute @DEFAULT_SINK@ | awk '{print $2}')"

pactl set-default-sink "$next_name"

while IFS= read -r sink_input; do
  [[ -n "$sink_input" ]] && pactl move-sink-input "$sink_input" "$next_name"
done < <(pactl list short sink-inputs | awk '{print $1}')

if [[ "$mute_state" == "yes" ]]; then
  pactl set-sink-mute "$next_name" 1
else
  pactl set-sink-mute "$next_name" 0
fi

notify_audio "$next_description"
