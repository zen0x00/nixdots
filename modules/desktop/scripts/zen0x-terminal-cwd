#!/usr/bin/env bash
set -euo pipefail

terminal_pid="$(hyprctl activewindow -j 2>/dev/null | jq -r '.pid // empty')"
[[ -z "$terminal_pid" ]] && printf "%s\n" "$HOME" && exit 0

shell_pid="$(pgrep -P "$terminal_pid" | tail -n1 || true)"
[[ -z "$shell_pid" ]] && printf "%s\n" "$HOME" && exit 0

cwd="$(readlink -f "/proc/$shell_pid/cwd" 2>/dev/null || true)"
shell_path="$(readlink -f "/proc/$shell_pid/exe" 2>/dev/null || true)"

if grep -qs "$shell_path" /etc/shells && [[ -d "$cwd" ]]; then
  printf "%s\n" "$cwd"
else
  printf "%s\n" "$HOME"
fi
