#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "$0")")/.." && pwd)"

ENTRIES=(
    "  Lock"
    "  Suspend"
    "  Hibernate"
    "  Reboot"
    "  Shutdown"
    "  Logout"
)

selected=$(printf '%s\n' "${ENTRIES[@]}" \
    | rofi -dmenu -p "")

case "$selected" in
    *Lock)      hyprlock ;;
    *Suspend)   systemctl suspend ;;
    *Hibernate) systemctl hibernate ;;
    *Reboot)    systemctl reboot ;;
    *Shutdown)  systemctl poweroff ;;
    *Logout)    hyprctl dispatch exit ;;
esac
