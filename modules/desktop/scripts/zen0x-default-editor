#!/usr/bin/env bash
set -euo pipefail

defaults_file="${XDG_CONFIG_HOME:-$HOME/.config}/zen0x/defaults.sh"

ensure_defaults_file() {
  mkdir -p "$(dirname "$defaults_file")"
  [[ -f "$defaults_file" ]] || printf "#!/usr/bin/env bash\n" > "$defaults_file"
}

set_env_line() {
  local key="$1"
  local value="$2"
  ensure_defaults_file
  if grep -q "^export $key=" "$defaults_file" 2>/dev/null; then
    sed -i "s|^export $key=.*|export $key=\"$value\"|" "$defaults_file"
  else
    printf 'export %s="%s"\n' "$key" "$value" >> "$defaults_file"
  fi
}

if (($# == 0)); then
  awk -F'"' '/^export EDITOR=/{print $2}' "$defaults_file" 2>/dev/null || true
  exit 0
fi

case "$1" in
  micro|nvim|vim|helix|code|cursor|zed|emacs) ;;
  *)
    echo "Usage: zen0x-default-editor [micro|nvim|vim|helix|code|cursor|zed|emacs]" >&2
    exit 1
    ;;
esac

set_env_line EDITOR "$1"
set_env_line VISUAL "$1"

command -v notify-send >/dev/null 2>&1 && notify-send "Default editor" "$1 (new shells only)"
